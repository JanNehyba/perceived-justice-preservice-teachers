// Figure 6.1 (CZ) — Evoluce sebehodnoticího nástroje (pět verzí), česká verze
// 06_evoluce_nastroje.dot. Stejná struktura/barvy; přeloženy jen popisky.
digraph evolution {
  rankdir=LR;
  bgcolor="white";
  node [fontname="Arial", fontsize=10, shape=box, style="rounded,filled", penwidth=1.2, margin="0.16,0.10"];
  edge [fontname="Arial", fontsize=9, color="#6E6E6E", fontcolor="#6E6E6E", arrowsize=0.8];
  graph [ranksep=0.75, nodesep=0.3];

  V2019 [label="2019 · v1\n21 položek\n3. osoba, deskriptivní\n(jen znění)", fillcolor="#EFEFEF", fontcolor="#6E6E6E", color="#B8B8B8", style="rounded,filled,dashed"];
  V2020 [label="2020 · v2\nn = 375 · 23 položek\n3. osoba, normativní\nsouhlasová škála", fillcolor="#FFD9B8", color="#FF7300"];
  V2021 [label="2021 · v3\nn = 433 · 36→26 položek\n1. osoba\nsouhlasová škála", fillcolor="#FFD9B8", color="#FF7300"];
  V2022 [label="2022 · v4\nn = 263 · 26 položek\n1. osoba\nsouhlasová škála", fillcolor="#FFD9B8", color="#FF7300"];
  V2023 [label="2023–26 · v5 (finální)\nn = 744 · 26 položek\n1. osoba\nškála spravedlnosti", fillcolor="#0000DC", fontcolor="white", color="#0000DC", penwidth=2];

  V2019 -> V2020 [label="  PERSPEKTIVA\n  deskriptivní → normativní", fontcolor="black"];
  V2020 -> V2021 [label="  OSOBA\n  3. → 1.;  zásobník 36 → EFA 26", fontcolor="black"];
  V2021 -> V2022 [label="  konsolidace\n  (+ BIDR)"];
  V2022 -> V2023 [label="  ŠKÁLA\n  souhlas → spravedlnost\n  přeformulace položek 16, 22", penwidth=2, color="#F01928", fontcolor="#F01928"];
}
